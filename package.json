{
  "name": "network-first-aid",
  "version": "0.1.1",
  "private": true,
  "description": "Windows network diagnostics, repair, backup and restore utility",
  "author": "Sober",
  "repository": {
    "type": "git",
    "url": "https://github.com/soberbw-hash/network-first-aid.git"
  },
  "homepage": "https://github.com/soberbw-hash/network-first-aid#readme",
  "packageManager": "pnpm@11.4.0",
  "scripts": {
    "dev": "tauri dev",
    "dev:renderer": "vite",
    "build": "corepack pnpm build:renderer",
    "build:renderer": "vite build",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "node --import tsx --test tests/*.test.ts",
    "tauri": "tauri",
    "dist:win": "powershell -NoLogo -NoProfile -ExecutionPolicy Bypass -File scripts/package-windows.ps1"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "lucide-react": "^0.511.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@types/node": "^22.15.3",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react-swc": "^3.8.0",
    "tsx": "^4.21.0",
    "typescript": "^7.0.2",
    "vite": "^6.3.5"
  }
}
